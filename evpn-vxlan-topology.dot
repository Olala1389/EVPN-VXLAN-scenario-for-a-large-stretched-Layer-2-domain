digraph EVPN_VXLAN_Topology {
    graph [
        label="EVPN-VXLAN Scenario: Large Stretched Layer 2 Domain"
        labelloc="t"
        fontsize=20
        fontname="Helvetica"
        splines=polyline
        rankdir=TB
        nodesep=0.8
        ranksep=1.0
        bgcolor="white"
    ]
    node [fontname="Helvetica" fontsize=11]
    edge [fontname="Helvetica" fontsize=10]

    // ── WAN / Backbone ──────────────────────────────────────────
    subgraph cluster_wan {
        label="WAN / IP Backbone"
        style=filled
        color="#E8E8E8"
        fontsize=14

        wan [label="IP Backbone\n(Inter-DC Transport)" shape=diamond style=filled fillcolor="#FFD700" width=2.2]
    }

    // ── Data Centre 1 ────────────────────────────────────────────
    subgraph cluster_dc1 {
        label="Data Centre 1"
        style=filled
        color="#DDEEFF"
        fontsize=14

        subgraph cluster_dc1_rr {
            label="BGP Route Reflectors (DC1)"
            style=dashed
            color="#AAAAFF"
            rr1 [label="RR1\n(BGP RR)" shape=hexagon style=filled fillcolor="#B0C4DE" width=1.6]
            rr2 [label="RR2\n(BGP RR)" shape=hexagon style=filled fillcolor="#B0C4DE" width=1.6]
        }

        subgraph cluster_dc1_spine {
            label="Spine Layer (DC1)"
            style=dashed
            color="#AABBCC"
            spine1 [label="Spine-1\n(DC1)" shape=box style=filled fillcolor="#87CEEB" width=1.6]
            spine2 [label="Spine-2\n(DC1)" shape=box style=filled fillcolor="#87CEEB" width=1.6]
        }

        subgraph cluster_dc1_leaf {
            label="Leaf / VTEP Layer (DC1)"
            style=dashed
            color="#99BBCC"
            leaf1 [label="Leaf-1 / VTEP-1\nVNI 10000\nLoopback: 10.0.0.1" shape=box style=filled fillcolor="#90EE90" width=2.2]
            leaf2 [label="Leaf-2 / VTEP-2\nVNI 10000\nLoopback: 10.0.0.2" shape=box style=filled fillcolor="#90EE90" width=2.2]
            leaf3 [label="Leaf-3 / VTEP-3\nVNI 10000\nLoopback: 10.0.0.3" shape=box style=filled fillcolor="#90EE90" width=2.2]
        }

        subgraph cluster_dc1_hosts {
            label="Servers (DC1)"
            style=dashed
            color="#AACCAA"
            host1 [label="Server-A\n192.168.10.11" shape=ellipse style=filled fillcolor="#FFFACD"]
            host2 [label="Server-B\n192.168.10.12" shape=ellipse style=filled fillcolor="#FFFACD"]
            host3 [label="Server-C\n192.168.10.13" shape=ellipse style=filled fillcolor="#FFFACD"]
        }
    }

    // ── Data Centre 2 ────────────────────────────────────────────
    subgraph cluster_dc2 {
        label="Data Centre 2"
        style=filled
        color="#FFEEDD"
        fontsize=14

        subgraph cluster_dc2_rr {
            label="BGP Route Reflectors (DC2)"
            style=dashed
            color="#FFAAAA"
            rr3 [label="RR3\n(BGP RR)" shape=hexagon style=filled fillcolor="#F4A460" width=1.6]
            rr4 [label="RR4\n(BGP RR)" shape=hexagon style=filled fillcolor="#F4A460" width=1.6]
        }

        subgraph cluster_dc2_spine {
            label="Spine Layer (DC2)"
            style=dashed
            color="#CCBBAA"
            spine3 [label="Spine-3\n(DC2)" shape=box style=filled fillcolor="#FFA07A" width=1.6]
            spine4 [label="Spine-4\n(DC2)" shape=box style=filled fillcolor="#FFA07A" width=1.6]
        }

        subgraph cluster_dc2_leaf {
            label="Leaf / VTEP Layer (DC2)"
            style=dashed
            color="#CCBBAA"
            leaf4 [label="Leaf-4 / VTEP-4\nVNI 10000\nLoopback: 10.0.1.1" shape=box style=filled fillcolor="#90EE90" width=2.2]
            leaf5 [label="Leaf-5 / VTEP-5\nVNI 10000\nLoopback: 10.0.1.2" shape=box style=filled fillcolor="#90EE90" width=2.2]
            leaf6 [label="Leaf-6 / VTEP-6\nVNI 10000\nLoopback: 10.0.1.3" shape=box style=filled fillcolor="#90EE90" width=2.2]
        }

        subgraph cluster_dc2_hosts {
            label="Servers (DC2)"
            style=dashed
            color="#CCAAAA"
            host4 [label="Server-D\n192.168.10.14" shape=ellipse style=filled fillcolor="#FFFACD"]
            host5 [label="Server-E\n192.168.10.15" shape=ellipse style=filled fillcolor="#FFFACD"]
            host6 [label="Server-F\n192.168.10.16" shape=ellipse style=filled fillcolor="#FFFACD"]
        }
    }

    // ── WAN connections ──────────────────────────────────────────
    spine1 -> wan [label="eBGP EVPN" dir=both color="#666666" style=bold]
    spine2 -> wan [label="eBGP EVPN" dir=both color="#666666" style=bold]
    wan -> spine3 [label="eBGP EVPN" dir=both color="#666666" style=bold]
    wan -> spine4 [label="eBGP EVPN" dir=both color="#666666" style=bold]

    // ── DC1 control-plane (RR <-> Spine) ─────────────────────────
    rr1 -> spine1 [label="iBGP EVPN" dir=both color="#0000CC" style=dashed]
    rr1 -> spine2 [label="iBGP EVPN" dir=both color="#0000CC" style=dashed]
    rr2 -> spine1 [label="iBGP EVPN" dir=both color="#0000CC" style=dashed]
    rr2 -> spine2 [label="iBGP EVPN" dir=both color="#0000CC" style=dashed]

    // ── DC1 underlay (Spine <-> Leaf) ────────────────────────────
    spine1 -> leaf1 [dir=both color="#444444"]
    spine1 -> leaf2 [dir=both color="#444444"]
    spine1 -> leaf3 [dir=both color="#444444"]
    spine2 -> leaf1 [dir=both color="#444444"]
    spine2 -> leaf2 [dir=both color="#444444"]
    spine2 -> leaf3 [dir=both color="#444444"]

    // ── DC1 server connections ────────────────────────────────────
    leaf1 -> host1 [dir=both color="#228B22" label="VLAN 10"]
    leaf2 -> host2 [dir=both color="#228B22" label="VLAN 10"]
    leaf3 -> host3 [dir=both color="#228B22" label="VLAN 10"]

    // ── DC2 control-plane (RR <-> Spine) ─────────────────────────
    rr3 -> spine3 [label="iBGP EVPN" dir=both color="#CC6600" style=dashed]
    rr3 -> spine4 [label="iBGP EVPN" dir=both color="#CC6600" style=dashed]
    rr4 -> spine3 [label="iBGP EVPN" dir=both color="#CC6600" style=dashed]
    rr4 -> spine4 [label="iBGP EVPN" dir=both color="#CC6600" style=dashed]

    // ── DC2 underlay (Spine <-> Leaf) ────────────────────────────
    spine3 -> leaf4 [dir=both color="#444444"]
    spine3 -> leaf5 [dir=both color="#444444"]
    spine3 -> leaf6 [dir=both color="#444444"]
    spine4 -> leaf4 [dir=both color="#444444"]
    spine4 -> leaf5 [dir=both color="#444444"]
    spine4 -> leaf6 [dir=both color="#444444"]

    // ── DC2 server connections ────────────────────────────────────
    leaf4 -> host4 [dir=both color="#228B22" label="VLAN 10"]
    leaf5 -> host5 [dir=both color="#228B22" label="VLAN 10"]
    leaf6 -> host6 [dir=both color="#228B22" label="VLAN 10"]

    // ── VXLAN tunnels (data-plane, inter-DC stretched L2) ─────────
    leaf1 -> leaf4 [label="VXLAN Tunnel\nVNI 10000" dir=both color="#CC0000" style=bold constraint=false]
    leaf2 -> leaf5 [label="VXLAN Tunnel\nVNI 10000" dir=both color="#CC0000" style=bold constraint=false]
    leaf3 -> leaf6 [label="VXLAN Tunnel\nVNI 10000" dir=both color="#CC0000" style=bold constraint=false]

    // ── Legend ────────────────────────────────────────────────────
    subgraph cluster_legend {
        label="Legend"
        style=filled
        color="#F0F0F0"
        fontsize=12
        rank=sink

        lg1 [label="──── Underlay (OSPF/IS-IS)" shape=plaintext]
        lg2 [label="- - - iBGP EVPN Control Plane" shape=plaintext]
        lg3 [label="════ VXLAN Tunnel (Data Plane)" shape=plaintext]
        lg4 [label="Green box  = VTEP (Leaf Switch)" shape=plaintext]
        lg5 [label="Blue hex   = BGP Route Reflector" shape=plaintext]
        lg6 [label="Yellow ellipse = Server / Host" shape=plaintext]
        lg1 -> lg2 [style=invis]
        lg2 -> lg3 [style=invis]
        lg3 -> lg4 [style=invis]
        lg4 -> lg5 [style=invis]
        lg5 -> lg6 [style=invis]
    }
}
